// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                   String   @id @default(cuid())
  email                String   @unique
  passwordHash         String   @map("password_hash")
  fullName             String?  @map("full_name")
  selectedPlan         Json?    @map("selected_plan")
  
  // Questionnaire Data (from questionnaire page)
  questionnaireData    Json?    @map("questionnaire_data")
  cryptoAssets         String[] @map("crypto_assets")
  forexPairs           String[] @map("forex_pairs")
  otherForexPair       String?  @map("other_forex_pair")
  screenshotUrl        String?  @map("screenshot_url")
  
  // Risk Management Plan Data (from risk management page)
  riskManagementPlan   Json?    @map("risk_management_plan")
  
  // Trading Preferences (from trading preferences page)
  tradingPreferences   Json?    @map("trading_preferences")
  
  // Account Status
  status               Status   @default(PENDING)
  planActivatedAt      DateTime? @map("plan_activated_at")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")
  
  // Relations
  payments             Payment[]
  trades               Trade[]
  
  @@index([email])
  @@index([status])
  @@index([createdAt])
  @@map("users")
}

model Payment {
  id              String   @id @default(cuid())
  userId          String   @map("user_id")
  planName        String   @map("plan_name")
  originalPrice   Float    @map("original_price")
  discount        Float    @default(0)
  finalPrice      Float    @map("final_price")
  couponCode      String?  @map("coupon_code")
  paymentMethod   String   @map("payment_method")
  status          String   @default("pending")
  transactionId   String?  @map("transaction_id")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  
  // Relations
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("payments")
}

model Trade {
  id                 String    @id @default(cuid())
  tradeNumber        Int       @map("trade_number")
  riskAmount         Float     @map("risk_amount")
  profitTarget       Float     @map("profit_target")
  cumulativeProfit   Float     @map("cumulative_profit")
  progressPercentage Float?    @map("progress_percentage")
  
  userId             String    @map("user_id")
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")
  
  @@index([userId])
  @@index([createdAt])
  @@map("trades")
}

enum Status {
  PENDING
  PROCESSING
  COMPLETED
  REJECTED
  ACTIVE
}
